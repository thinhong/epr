(function () {
  "use strict";

  function init() {
    if (!window.EPR) return;
    EPR.injectStyles();
    injectGameStyles();
    var mount = document.getElementById("cusum-game");
    if (!mount) return;
    if (mount.getAttribute("data-built") === "1") return;
    mount.setAttribute("data-built", "1");
    build(mount);
  }

  function injectGameStyles() {
    if (document.getElementById("epr-cusum-styles")) return;
    var css =
      ".epr-fig .epr-hint{font-size:1.02rem;color:var(--ink);margin:6px 0 10px;background:var(--surfaceAlt);border-radius:10px;padding:9px 13px;border-left:4px solid var(--accent)}" +
      ".epr-fig .epr-hint.good{border-left-color:var(--expected)}.epr-fig .epr-hint.warn{border-left-color:var(--alarm)}.epr-fig .epr-hint.bad{border-left-color:var(--alarmStrong)}" +
      ".epr-fig .epr-bar{display:flex;flex-wrap:wrap;gap:8px;align-items:center;margin:8px 0 2px}" +
      ".epr-fig .epr-seg{display:inline-flex;border:1px solid var(--grid);border-radius:10px;overflow:hidden}" +
      ".epr-fig .epr-seg button{appearance:none;border:0;background:var(--surface);color:var(--muted);font:inherit;font-size:.95rem;font-weight:500;padding:9px 15px;min-height:44px;cursor:pointer}" +
      ".epr-fig .epr-seg button.on{background:var(--accent);color:#fff}" +
      ".epr-fig .epr-spin{font-variant-numeric:tabular-nums}";
    var s = document.createElement("style");
    s.id = "epr-cusum-styles"; s.textContent = css;
    document.head.appendChild(s);
  }

  var NS = "http://www.w3.org/2000/svg";
  function svg(tag, attrs, parent) {
    var e = document.createElementNS(NS, tag);
    if (attrs) for (var k in attrs) if (attrs.hasOwnProperty(k)) e.setAttribute(k, attrs[k]);
    if (parent) parent.appendChild(e);
    return e;
  }
  function clear(n) { while (n && n.firstChild) n.removeChild(n.firstChild); }
  function lin(d0, d1, r0, r1) { return function (v) { return r0 + (v - d0) / (d1 - d0) * (r1 - r0); }; }

  // --- model (unchanged): honest scale PXG px per mL is shared by vial overfill AND tank ---
  var N = 40, MU0 = 3, SIGMA = 0.1, DELTA = 0.2, K = 0.1, H = 0.7, PXG = 80, TMAX = 1.2;
  // --- stage geometry ---
  var BASE = 212;
  var HX = 90, hCapTop = 50, hBTOP = 105, hFL = 150, hBOT = 210;
  var BELT_L = 190, BELT_R = 626, SLOT = (BELT_R - BELT_L) / N;
  var bBTOP = 160, bFL = 180, bBOT = 210;
  var TANK_X = 650, TANK_W = 70, TANK_BOT = 212, TANK_TOP = TANK_BOT - TMAX * PXG;
  var rimY = TANK_BOT - H * PXG;
  function slotX(i) { return BELT_L + (i + 0.5) * SLOT; }

  function build(mount) {
    var C = EPR.colors();
    var LIQ = C.expected, OVER = C.alarm, GLASS = C.glass, GST = C.glassStroke,
        CAP = C.cap, CAPHI = C.capHi, CAPEDGE = C.capEdge, CRIMP = C.crimp,
        BELT = C.belt, BELT_HI = "#aab6c4", ROLLER = C.roller, SERR = "#5a636e";
    var st = { mode: "cusum", formula: false, step: -1, round: null, stopIndex: null, rang: null, revealed: false, ended: false, waterTween: null, bellTimer: null };

    mount.innerHTML =
      '<div class="epr-fig">' +
        '<div class="epr-head"><div><div class="epr-kicker">Precision vaccine line</div>' +
        '<div class="epr-title">The overfill tank</div></div></div>' +
        '<div class="epr-hint" id="g-hint"></div>' +
        '<svg class="epr-stage" id="g-stage" viewBox="0 0 760 264" role="img" aria-label="An inspection panel showing one enlarged vaccine vial being measured, a conveyor belt of finished vials, and a tank catching the overfill"></svg>' +
        '<div class="epr-readouts" id="g-read"></div>' +
        '<div class="epr-bar">' +
          '<button class="epr-btn primary" id="g-next">&#9654; Next vial</button>' +
          '<button class="epr-btn" id="g-reset">&#8635; New batch</button>' +
          '<span class="epr-spacer"></span>' +
          '<span class="epr-seg" id="g-mode"><button data-m="manual">You measure</button><button data-m="cusum" class="on">CUSUM</button></span>' +
          '<button class="epr-chiptog" id="g-formula">Formula</button>' +
        '</div>' +
        '<svg class="epr-chart" id="g-chart" viewBox="0 0 760 130" role="img" aria-label="Wasted vaccine caught in the tank, per vial"></svg>' +
        '<div id="g-formula-box"></div>' +
        '<div class="epr-result" id="g-result"></div>' +
      '</div>';

    var $ = function (id) { return mount.querySelector(id); };
    var stage = $("#g-stage"), chart = $("#g-chart"), hint = $("#g-hint"),
        read = $("#g-read"), result = $("#g-result"), formulaBox = $("#g-formula-box");

    var S = {};
    buildStage();
    function buildStage() {
      clear(stage);
      var g = svg("g", {}, stage), sx, rx;
      // defs: clip for the hero vial body
      var defs = svg("defs", {}, g);
      var cp = svg("clipPath", { id: "eprHeroClip" }, defs);
      svg("rect", { x: HX - 40, y: hBTOP, width: 80, height: hBOT - hBTOP, rx: 12 }, cp);

      // inspection panel (signals this is a zoomed-in detail view)
      svg("rect", { x: 10, y: 40, width: 166, height: 196, rx: 14, fill: C.surfaceAlt, stroke: C.grid }, g);
      svg("text", { x: HX, y: 230, "font-size": 12, "font-weight": 600, fill: C.muted, "text-anchor": "middle" }, g).textContent = "Now measuring";

      // conveyor belt (carries finished vials toward the tank)
      var belt = svg("g", {}, g);
      svg("rect", { x: BELT_L - 16, y: BASE, width: (BELT_R + 20) - (BELT_L - 16), height: 10, fill: BELT }, belt);
      svg("rect", { x: BELT_L - 16, y: BASE, width: (BELT_R + 20) - (BELT_L - 16), height: 3, fill: BELT_HI }, belt);
      for (sx = BELT_L - 10; sx < BELT_R + 18; sx += 20) svg("line", { x1: sx, y1: BASE + 2, x2: sx - 4, y2: BASE + 9, stroke: "#6e7c8d", "stroke-width": 1, opacity: 0.5 }, belt);
      for (rx = BELT_L - 8; rx < BELT_R + 20; rx += 34) svg("circle", { cx: rx, cy: BASE + 16, r: 6, fill: ROLLER, stroke: BELT, "stroke-width": 1 }, belt);
      svg("rect", { x: BELT_L - 18, y: BASE + 20, width: 5, height: 16, fill: "#9aa7b5" }, belt);
      svg("rect", { x: BELT_R + 14, y: BASE + 20, width: 5, height: 16, fill: "#9aa7b5" }, belt);

      // hero shelf + soft shadow inside the panel
      svg("ellipse", { cx: HX, cy: BASE + 2, rx: 38, ry: 4.5, fill: "#1f2933", opacity: 0.06 }, g);
      svg("rect", { x: HX - 46, y: BASE, width: 92, height: 8, rx: 3, fill: BELT }, g);
      svg("rect", { x: HX - 46, y: BASE, width: 92, height: 3, fill: BELT_HI }, g);

      // filler nozzle above the hero vial
      var noz = svg("g", {}, g);
      svg("rect", { x: HX - 26, y: 27, width: 52, height: 10, rx: 3, fill: "#c2ccd6", stroke: GST, "stroke-width": 1 }, noz);
      svg("rect", { x: HX - 4, y: 36, width: 8, height: 9, rx: 1, fill: "#aab6c4" }, noz);

      S.lineG = svg("g", {}, g);     // hero + belt vials (redrawn each step)
      S.leakG = svg("g", {}, g);
      S.wBubble = svg("g", { opacity: 0 }, g);
      svg("rect", { x: -34, y: -13, width: 68, height: 24, rx: 8, fill: C.ink }, S.wBubble);
      svg("path", { d: "M -6 10 L 0 17 L 6 10 Z", fill: C.ink }, S.wBubble);
      S.wText = svg("text", { x: 0, y: 4, "font-size": 13.5, "font-weight": 700, fill: "#fff", "text-anchor": "middle" }, S.wBubble);

      // overfill tank with funnel
      var tg = svg("g", {}, g);
      svg("path", { d: "M " + (TANK_X + 8) + " " + (TANK_TOP - 13) + " L " + (TANK_X + TANK_W - 8) + " " + (TANK_TOP - 13) + " L " + (TANK_X + TANK_W / 2 + 7) + " " + TANK_TOP + " L " + (TANK_X + TANK_W / 2 - 7) + " " + TANK_TOP + " Z", fill: "#d2dae3", stroke: C.muted, "stroke-width": 1 }, tg);
      svg("rect", { x: TANK_X, y: TANK_TOP, width: TANK_W, height: TANK_BOT - TANK_TOP, rx: 8, fill: C.surface, stroke: C.ink, "stroke-width": 2 }, tg);
      S.water = svg("rect", { x: TANK_X + 4, y: TANK_BOT - 4, width: TANK_W - 8, height: 0, rx: 4, fill: OVER, opacity: 0.85 }, tg);
      [0, 0.5, 1.0].forEach(function (gv) {
        var ty = TANK_BOT - gv * PXG;
        svg("line", { x1: TANK_X - 5, y1: ty, x2: TANK_X, y2: ty, stroke: C.muted, "stroke-width": 1 }, tg);
        svg("text", { x: TANK_X - 8, y: ty + 4, "font-size": 10.5, fill: C.muted, "text-anchor": "end" }, tg).textContent = gv.toFixed(1);
      });
      S.rim = svg("line", { x1: TANK_X, y1: rimY, x2: TANK_X + TANK_W, y2: rimY, stroke: C.alarmStrong, "stroke-width": 2, "stroke-dasharray": "6 4" }, tg);
      svg("text", { x: TANK_X + TANK_W + 5, y: rimY + 4, "font-size": 13, "font-weight": 600, fill: C.alarmStrong }, tg).textContent = "H";
      svg("text", { x: TANK_X + TANK_W / 2, y: TANK_BOT + 19, "font-size": 12.5, "font-weight": 600, fill: C.ink, "text-anchor": "middle" }, tg).textContent = "overfill tank (mL)";
      S.spout = svg("rect", { x: TANK_X + TANK_W - 3, y: TANK_BOT - 12, width: 8, height: 5, rx: 1, fill: C.muted, opacity: 0 }, tg);
      S.bellG = svg("g", { transform: "translate(" + (TANK_X + TANK_W / 2) + ",96)" }, tg);
      S.bell = svg("path", { d: "M -8 4 Q -8 -8 0 -8 Q 8 -8 8 4 L 10 8 L -10 8 Z", fill: "#cbd5e1", stroke: C.muted, "stroke-width": 1 }, S.bellG);
      svg("circle", { cx: 0, cy: 10, r: 2, fill: C.muted }, S.bellG);
    }

    // draw one vial as a reusable shape at (cx) and (top), scaled by s.
    // The big "hero" (s=1, detailed: cap, crimp, neck, shoulder, label, gloss)
    function heroVial(dev, ov) {
      var g = S.lineG;
      // aluminium flip cap
      svg("rect", { x: HX - 27, y: hCapTop, width: 54, height: 24, rx: 5, fill: CAP }, g);
      svg("rect", { x: HX - 21, y: hCapTop + 4, width: 15, height: 15, rx: 2, fill: CAPHI }, g);
      svg("rect", { x: HX + 16, y: hCapTop + 2, width: 5, height: 19, rx: 1.5, fill: CAPEDGE }, g);
      // crimp ring + serrations
      var cy = hCapTop + 23;
      svg("rect", { x: HX - 22, y: cy, width: 44, height: 10, fill: CRIMP }, g);
      for (var s1 = HX - 18; s1 <= HX + 18; s1 += 5) svg("line", { x1: s1, y1: cy + 1, x2: s1, y2: cy + 9, stroke: SERR, "stroke-width": 0.8, opacity: 0.4 }, g);
      // neck
      svg("rect", { x: HX - 15, y: cy + 9, width: 30, height: 11, fill: GLASS, stroke: GST, "stroke-width": 0.8 }, g);
      // shoulder
      svg("path", { d: "M " + (HX - 15) + " " + (cy + 20) + " C " + (HX - 19) + " " + (cy + 26) + " " + (HX - 34) + " " + (cy + 28) + " " + (HX - 40) + " " + hBTOP + " L " + (HX + 40) + " " + hBTOP + " C " + (HX + 34) + " " + (cy + 28) + " " + (HX + 19) + " " + (cy + 26) + " " + (HX + 15) + " " + (cy + 20) + " Z", fill: GLASS, stroke: GST, "stroke-width": 0.9 }, g);
      // glass body
      svg("rect", { x: HX - 40, y: hBTOP, width: 80, height: hBOT - hBTOP, rx: 12, fill: GLASS, stroke: GST, "stroke-width": 0.9 }, g);
      // liquid + overfill (clipped to body)
      var cg = svg("g", { "clip-path": "url(#eprHeroClip)" }, g);
      if (dev != null) {
        svg("rect", { x: HX - 40, y: hFL, width: 80, height: hBOT - hFL, fill: LIQ, opacity: 0.30 }, cg);
        if (ov > 0) { var at = Math.max(hBTOP + 1, hFL - ov * PXG); svg("rect", { x: HX - 40, y: at, width: 80, height: hFL - at, fill: OVER, opacity: 0.9 }, cg); }
      }
      // gloss highlights
      svg("rect", { x: HX - 31, y: hBTOP + 8, width: 7, height: 74, rx: 3.5, fill: "#ffffff", opacity: 0.5 }, cg);
      svg("rect", { x: HX - 20, y: hBTOP + 8, width: 3, height: 74, rx: 1.5, fill: "#ffffff", opacity: 0.82 }, cg);
      // white label
      svg("rect", { x: HX - 36, y: hFL + 12, width: 72, height: 46, rx: 5, fill: "#ffffff", stroke: C.grid, opacity: dev == null ? 0.5 : 1 }, g);
      // barcode
      var bx = HX - 31, bw = [2, 1, 3, 1, 2, 1, 1, 3, 2, 1, 2];
      for (var bi = 0; bi < bw.length; bi++) { svg("rect", { x: bx, y: hFL + 18, width: bw[bi], height: 28, fill: dev == null ? "#c7d0da" : C.ink }, g); bx += bw[bi] + 1.6; }
      // two red bands + a faint text line
      svg("line", { x1: HX + 1, y1: hFL + 22, x2: HX + 31, y2: hFL + 22, stroke: C.alarmStrong, "stroke-width": 2.4, opacity: dev == null ? 0.4 : 1 }, g);
      svg("line", { x1: HX + 1, y1: hFL + 32, x2: HX + 31, y2: hFL + 32, stroke: C.alarmStrong, "stroke-width": 2.4, opacity: dev == null ? 0.4 : 1 }, g);
      svg("line", { x1: HX + 1, y1: hFL + 42, x2: HX + 25, y2: hFL + 42, stroke: "#cbd5e1", "stroke-width": 2, opacity: dev == null ? 0.4 : 1 }, g);
      // fill line + label
      svg("line", { x1: HX - 40, y1: hFL, x2: HX + 44, y2: hFL, stroke: LIQ, "stroke-width": 1.6, "stroke-dasharray": "5 5" }, g);
      svg("text", { x: HX - 46, y: hFL - 4, "font-size": 10.5, fill: LIQ, "text-anchor": "end" }, g).textContent = "fill line";
      svg("text", { x: HX - 46, y: hFL + 9, "font-size": 9.5, fill: C.muted, "text-anchor": "end" }, g).textContent = "3.0 mL";
    }

    // the compact "belt" vial (finished vials lined up in order)
    function beltVial(cx, dev, ov) {
      var g = S.lineG;
      var bw = Math.min(11, SLOT - 1.6), hw = bw / 2;
      var capW = Math.max(5, bw * 0.92), chw = capW / 2;
      // cap
      svg("rect", { x: cx - chw, y: bBTOP - 10, width: capW, height: 6.5, rx: 1.5, fill: CAP }, g);
      svg("rect", { x: cx - chw + 1, y: bBTOP - 9, width: capW * 0.34, height: 4, rx: 0.6, fill: CAPHI }, g);
      // neck
      svg("rect", { x: cx - bw * 0.28, y: bBTOP - 4, width: bw * 0.56, height: 5, fill: GLASS, stroke: GST, "stroke-width": 0.5 }, g);
      // body (rounded top reads as shoulders at this size)
      svg("rect", { x: cx - hw, y: bBTOP, width: bw, height: bBOT - bBTOP, rx: 2.6, fill: GLASS, stroke: GST, "stroke-width": 0.7 }, g);
      // liquid
      svg("rect", { x: cx - hw + 0.8, y: bFL, width: bw - 1.6, height: bBOT - 0.8 - bFL, fill: LIQ, opacity: 0.3 }, g);
      // overfill (amber top) - same px-per-mL as the tank
      if (ov > 0) { var at = Math.max(bBTOP + 0.8, bFL - ov * PXG); svg("rect", { x: cx - hw + 0.8, y: at, width: bw - 1.6, height: bFL - at, fill: OVER, opacity: 0.9 }, g); }
      // gloss
      svg("rect", { x: cx - hw + 1.4, y: bBTOP + 3, width: 1.4, height: bBOT - bBTOP - 8, rx: 0.7, fill: "#ffffff", opacity: 0.7 }, g);
    }

    function drawLineup(newOver) {
      clear(S.lineG);
      // finished vials on the belt: 0 .. step-1
      for (var i = 0; i < st.step; i++) {
        var dev = st.round.x[i] - MU0;
        beltVial(slotX(i), dev, Math.max(0, dev));
      }
      // current vial shown big in the inspection panel (or an empty preview)
      if (st.step >= 0) {
        var d = st.round.x[st.step] - MU0;
        var ov = (newOver != null) ? newOver : Math.max(0, d);
        heroVial(d, ov);
      } else {
        heroVial(null, 0);
      }
    }
    function showWeight(w) {
      S.wBubble.setAttribute("transform", "translate(" + HX + ",16)");
      S.wText.textContent = w.toFixed(2) + " mL";
      S.wBubble.setAttribute("opacity", 1);
    }
    function leakDrip() {
      if (EPR.reducedMotion()) return;
      clear(S.leakG);
      S.spout.setAttribute("opacity", 0.9);
      var d = svg("circle", { cx: TANK_X + TANK_W + 2, cy: TANK_BOT - 8, r: 2.4, fill: OVER, opacity: 0.8 }, S.leakG);
      EPR.tween(TANK_BOT - 8, TANK_BOT + 16, 340, function (y) { d.setAttribute("cy", y); d.setAttribute("opacity", Math.max(0, 0.8 * (1 - (y - (TANK_BOT - 8)) / 24))); }, function () { if (d.parentNode) d.parentNode.removeChild(d); S.spout.setAttribute("opacity", 0); });
    }

    function newRound() {
      var seed = Math.floor(Math.random() * 1e9), rnd = EPR.rng(seed), z = [];
      for (var i = 0; i < N; i++) z.push(EPR.gauss(rnd));
      st.round = { z: z, driftStart: 10 + Math.floor(rnd() * (N - 18)) };
      buildData();
      st.step = -1; st.stopIndex = null; st.rang = null; st.revealed = false; st.ended = false;
      clear(S.leakG); S.wBubble.setAttribute("opacity", 0); stillBell(); setTankStatic(0);
      result.classList.remove("show");
      setHint("Every vial of this expensive vaccine must fill to the <b>line</b>. Anything <b>over the line</b> (amber) is a wasted dose, straight off your margin, and the tank catches it. Click <b>Next vial</b>: the vial under the filler is shown up close, and each finished vial lines up on the belt so you watch the whole run.", "");
      drawLineup(null);
      renderReadouts(); drawChart();
    }
    function buildData() {
      var r = st.round, x = [], manual = [], cusum = [], pm = 0, pc = 0;
      for (var i = 0; i < N; i++) {
        x.push(EPR.round(MU0 + (i >= r.driftStart ? DELTA : 0) + r.z[i] * SIGMA, 2));
        var ov = Math.max(0, x[i] - MU0);
        pm = pm + ov; manual.push(pm);
        pc = Math.max(0, pc + ov - K); cusum.push(pc);
      }
      r.x = x; r.manual = manual; r.cusum = cusum;
    }
    function series() { return st.mode === "cusum" ? st.round.cusum : st.round.manual; }

    function setTankStatic(level) { tankTo(level, false); }
    function tankTo(level, animate) {
      var h = EPR.clamp(level, 0, TMAX) * PXG, over = level > H;
      S.water.setAttribute("fill", over ? C.alarmStrong : OVER);
      function ap(v) { S.water.setAttribute("height", v); S.water.setAttribute("y", TANK_BOT - 4 - v); }
      if (st.waterTween) st.waterTween.stop();
      var cur = parseFloat(S.water.getAttribute("height")) || 0;
      if (animate) st.waterTween = EPR.tween(cur, h, 240, ap); else ap(h);
      if (over) ringBell(); else stillBell();
    }
    function ringBell() {
      S.bell.setAttribute("fill", "#fcd34d");
      if (EPR.reducedMotion() || st.bellTimer) return;
      var n = 0, tx = TANK_X + TANK_W / 2;
      st.bellTimer = setInterval(function () {
        n++; S.bellG.setAttribute("transform", "translate(" + tx + ",96) rotate(" + (n % 2 ? 12 : -12) + ")");
        if (n > 5) { clearInterval(st.bellTimer); st.bellTimer = null; S.bellG.setAttribute("transform", "translate(" + tx + ",96)"); }
      }, 95);
    }
    function stillBell() { if (st.bellTimer) { clearInterval(st.bellTimer); st.bellTimer = null; } S.bell.setAttribute("fill", "#cbd5e1"); S.bellG.setAttribute("transform", "translate(" + (TANK_X + TANK_W / 2) + ",96)"); }

    function nextBottle() {
      if (st.ended || st.step >= N - 1) return;
      st.step++;
      var w = st.round.x[st.step], level = series()[st.step];
      renderReadouts();
      drawLineup(null);
      showWeight(w);
      if (st.mode === "cusum") leakDrip();
      tankTo(level, true);
      drawChart();
      afterStep();
    }
    function afterStep() {
      if (st.step >= 0 && series()[st.step] > H) { st.rang = st.step; st.ended = true; st.revealed = true; showResult(); return; }
      if (st.step >= N - 1) { st.ended = true; st.revealed = true; showResult(); }
    }

    function renderReadouts() {
      if (st.step < 0) { read.innerHTML = chip("vials", "0 of " + N) + chip("tank", "0.00 mL", "good"); return; }
      var w = st.round.x[st.step], dev = w - MU0, level = series()[st.step], over = level > H;
      read.innerHTML =
        chip("vial", "#" + (st.step + 1)) +
        chip("fill", w.toFixed(2) + " mL", Math.abs(dev) > 3 * SIGMA ? "warn" : "") +
        chip("over line", (dev >= 0 ? "+" : "") + dev.toFixed(2) + " mL", dev > 0 ? "warn" : "good") +
        chip("wasted", level.toFixed(2) + " mL", over ? "bad" : "") +
        chip("status", over ? "OVERFLOW" : "running", over ? "bad" : "good");
    }
    function chip(l, v, c) { return '<div class="epr-chip ' + (c || "") + '"><span>' + l + '</span><span class="v epr-spin">' + v + '</span></div>'; }

    var ML = 50, MR = 22, MT = 14, MB = 28, CW = 760, CH = 130;
    function clampY(v) { return Math.max(MT, Math.min(CH - MB, v)); }
    function drawChart() {
      clear(chart);
      var g = svg("g", {}, chart), s = series(), upto = st.step;
      var x = lin(0, N - 1, ML, CW - MR), yMax = Math.max(H * 1.7, 1.0), y = lin(0, yMax, CH - MB, MT);
      svg("line", { x1: ML, y1: y(0), x2: CW - MR, y2: y(0), stroke: C.muted, "stroke-width": 1 }, g);
      [0, H].forEach(function (t) { svg("text", { x: ML - 8, y: y(t) + 4, "font-size": 12, fill: C.muted, "text-anchor": "end" }, g).textContent = t.toFixed(1); });
      svg("text", { x: ML, y: MT - 1, "font-size": 11.5, fill: C.muted }, g).textContent = "wasted vaccine (mL)";
      svg("text", { x: (ML + CW - MR) / 2, y: CH - 3, "font-size": 12, fill: C.muted, "text-anchor": "middle" }, g).textContent = "vial number";
      svg("line", { x1: ML, y1: y(H), x2: CW - MR, y2: y(H), stroke: C.alarmStrong, "stroke-width": 2, "stroke-dasharray": "6 4" }, g);
      svg("text", { x: CW - MR, y: y(H) - 6, "font-size": 12.5, "font-weight": 600, fill: C.alarmStrong, "text-anchor": "end" }, g).textContent = "stop H";
      if (st.revealed) {
        var d = st.round.driftStart;
        svg("line", { x1: x(d), y1: MT, x2: x(d), y2: CH - MB, stroke: C.expected, "stroke-width": 1.6, "stroke-dasharray": "3 4" }, g);
        svg("text", { x: x(d) + 4, y: MT + 11, "font-size": 11.5, fill: C.expected }, g).textContent = "drift began";
      }
      if (upto >= 0) {
        var dd = "M" + x(0).toFixed(1) + " " + clampY(y(0)).toFixed(1) + " ";
        for (var i = 0; i <= upto; i++) dd += "L" + x(i).toFixed(1) + " " + clampY(y(s[i])).toFixed(1) + " ";
        dd += "L" + x(upto).toFixed(1) + " " + clampY(y(0)).toFixed(1) + " Z";
        svg("path", { d: dd, fill: C.accentSoft }, g);
        var dl = "";
        for (var j = 0; j <= upto; j++) dl += (j ? "L" : "M") + x(j).toFixed(1) + " " + clampY(y(s[j])).toFixed(1) + " ";
        svg("path", { d: dl, fill: "none", stroke: C.accent, "stroke-width": 2.3, "stroke-linejoin": "round", "stroke-linecap": "round" }, g);
        if (st.rang != null) svg("circle", { cx: x(st.rang), cy: clampY(y(s[st.rang])), r: 4.2, fill: C.alarmStrong }, g);
      }
      if (st.stopIndex != null) { svg("line", { x1: x(st.stopIndex), y1: MT, x2: x(st.stopIndex), y2: CH - MB, stroke: C.accent, "stroke-width": 2, opacity: 0.5 }, g); svg("text", { x: x(st.stopIndex), y: MT + 11, "font-size": 11.5, "font-weight": 600, fill: C.accent, "text-anchor": "middle" }, g).textContent = "you"; }
    }
    function setHint(html, cls) { hint.className = "epr-hint " + (cls || ""); hint.innerHTML = html; }

    function renderFormula() {
      if (!st.formula) { formulaBox.innerHTML = ""; return; }
      formulaBox.innerHTML =
        '<div class="epr-formula"><span class="s">tank</span> = ' + (st.mode === "cusum" ? 'max( 0 , ' : '') + '<span class="s">tank</span> + <span class="k">overfill</span>' + (st.mode === "cusum" ? ' &minus; <span class="k">tolerance</span> )' : '') + ' &nbsp; stop when <span class="s">tank</span> &gt; <span class="h">H</span></div>' +
        '<div class="epr-legend">' + leg(LIQ, "filled to the line (in spec)") + leg(OVER, "overfill = mL over the line (wasted)") + (st.mode === "cusum" ? leg(C.muted, "tolerance = 0.10 mL/vial leaks away") : "") + leg(C.alarmStrong, "H = stop level = 0.70 mL") + '</div>';
    }
    function leg(color, text) { return '<span class="epr-leg"><span class="epr-sw" style="background:' + color + '"></span>' + text + '</span>'; }

    function callDrift() {
      if (st.step < 0 || st.ended || st.stopIndex != null) return;
      st.stopIndex = st.step;
      setHint("You flagged the filler at vial " + (st.step + 1) + ". Keep going to the end of the batch to see how your call compares to the real drift and to the tank.", "");
      drawChart();
    }
    function reevaluate() {
      if (!st.round || st.step < 0) { st.ended = false; st.rang = null; return; }
      var s = series(), rang = -1;
      for (var i = 0; i <= st.step; i++) { if (s[i] > H) { rang = i; break; } }
      st.rang = rang >= 0 ? rang : null;
      st.ended = rang >= 0 || st.step >= N - 1;
      if (st.ended) { st.revealed = true; showResult(); }
      else { result.classList.remove("show"); setHint("Now running in <b>" + (st.mode === "cusum" ? "CUSUM" : "you-measure") + "</b> mode. Keep clicking <b>Next vial</b> to finish this same batch.", ""); }
    }
    function showResult() {
      var r = st.round, rang = st.rang != null ? st.rang : -1, you = st.stopIndex, ds = r.driftStart, cls;
      var msg = "<b>Batch over. The filler began overfilling at vial " + (ds + 1) + "</b> (teal line). ";
      if (rang >= 0 && rang < ds) { msg += (st.mode === "cusum" ? "The tank" : "Your running total") + " brimmed over at vial " + (rang + 1) + ", a false alarm that would stop a line still in spec."; cls = "bad"; }
      else if (rang >= 0) { msg += "The tank brimmed over at vial " + (rang + 1) + ", " + (rang - ds) + " vial" + (rang - ds === 1 ? "" : "s") + " after the drift. Stop and recalibrate the filler."; cls = "good"; }
      else { msg += "The batch finished and the tank never brimmed; the line stayed in spec."; cls = "warn"; }
      if (you != null) msg += " You flagged vial " + (you + 1) + (you >= ds ? "." : ", a false alarm.");
      if (st.mode === "manual") msg += " With no tolerance the tank fills on ordinary scatter too, so it overflows even on a healthy line; switch to CUSUM to allow a small tolerance.";
      result.className = "epr-result show " + cls; result.innerHTML = msg;
      drawChart();
      setHint("Batch over. Hit <b>New batch</b> for a fresh hidden drift, or flip the mode to replay this same batch under the other rule.", "");
    }

    $("#g-next").onclick = nextBottle;
    $("#g-reset").onclick = function () { stillBell(); newRound(); };
    mount.querySelectorAll("#g-mode button").forEach(function (b) {
      b.onclick = function () {
        st.mode = b.getAttribute("data-m");
        mount.querySelectorAll("#g-mode button").forEach(function (o) { o.classList.toggle("on", o === b); });
        reevaluate();
        if (st.step >= 0) setTankStatic(series()[st.step]);
        renderReadouts(); drawChart(); renderFormula();
      };
    });
    $("#g-formula").onclick = function () { st.formula = !st.formula; $("#g-formula").classList.toggle("on", st.formula); renderFormula(); };

    newRound();
    renderFormula();
  }

  if (document.readyState === "loading") document.addEventListener("DOMContentLoaded", init);
  else init();
})();
