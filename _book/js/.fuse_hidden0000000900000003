(function () {
  "use strict";

  function init() {
    if (!window.EPR) return;
    EPR.injectStyles();
    var mount = document.getElementById("cusum-epi");
    if (!mount) return;
    if (mount.getAttribute("data-built") === "1") return;
    mount.setAttribute("data-built", "1");
    build(mount);
  }

  var NS = "http://www.w3.org/2000/svg";
  function svg(tag, attrs, parent) {
    var e = document.createElementNS(NS, tag);
    if (attrs) for (var k in attrs) if (attrs.hasOwnProperty(k)) e.setAttribute(k, attrs[k]);
    if (parent) parent.appendChild(e);
    return e;
  }
  function clear(n) { while (n && n.firstChild) n.removeChild(n.firstChild); }
  function lin(d0, d1, r0, r1) { return function (v) { return r0 + (v - d0) / (d1 - d0) * (r1 - r0); }; }
  function mean(a) { var s = 0; for (var i = 0; i < a.length; i++) s += a[i]; return s / a.length; }
  function pois(l, rng) { var L = Math.exp(-l), k = 0, p = 1; do { k++; p *= rng(); } while (p > L); return k - 1; }

  // surveillance::algo.cusum defaults
  var K = 1.04, H = 2.26;
  var N = 40, B = 16, ONSET = 21;   // baseline weeks 1..B (idx 0..B-1); monitoring idx B..N-1; outbreak from idx ONSET

  function build(mount) {
    var C = EPR.colors();

    var rng = EPR.rng(42), counts = [];
    for (var i = 0; i < N; i++) counts.push(pois(i < ONSET ? 7 : 12, rng));
    var m = mean(counts.slice(0, B)), sm = Math.sqrt(m);
    var z = [], S = [], U = [], prev = 0, alarm = -1;
    for (i = 0; i < N; i++) { z.push(null); S.push(null); U.push(null); }
    for (i = B; i < N; i++) {
      z[i] = (counts[i] - m) / sm;
      U[i] = Math.ceil(m + sm * (H + K - prev));
      var s = Math.max(0, prev + (z[i] - K));
      S[i] = s; if (alarm < 0 && s >= H) alarm = i; prev = s;
    }

    var st = { cur: N - 1 };

    mount.innerHTML =
      '<div class="epr-fig">' +
        '<div class="epr-head"><div><div class="epr-kicker">surveillance::algo.cusum (defaults)</div>' +
        '<div class="epr-title">Computing an epidemic threshold with CUSUM</div></div></div>' +
        '<div id="ce-formula"></div>' +
        '<div class="epr-hint" id="ce-hint"></div>' +
        '<svg class="epr-chart" id="ce-chart" viewBox="0 0 760 300" role="img" aria-label="Weekly case counts with the CUSUM case-count threshold, and the standardized CUSUM statistic below" style="touch-action:none;cursor:ew-resize"></svg>' +
        '<input id="ce-scrub" type="range" min="' + B + '" max="' + (N - 1) + '" step="1" value="' + (N - 1) + '" style="width:100%;accent-color:var(--epr-accent,#2563eb);height:30px" aria-label="scrub weeks">' +
        '<div class="epr-readouts" id="ce-read"></div>' +
      '</div>';

    var $ = function (id) { return mount.querySelector(id); };
    var chart = $("#ce-chart"), hint = $("#ce-hint"), read = $("#ce-read"), fbox = $("#ce-formula"), scrub = $("#ce-scrub");

    fbox.innerHTML =
      '<div class="epr-formula" style="text-align:left;font-size:1.05rem">' +
        '<span class="mu">expected m</span> = mean of the ' + B + ' weeks before monitoring = <b>' + m.toFixed(2) + '</b> cases/wk &nbsp;(default <code>m = NULL</code>)<br>' +
        'standardize (<code>trans="standard"</code>): <span class="s">z</span><sub>t</sub> = ( x<sub>t</sub> &minus; <span class="mu">m</span> ) / &radic;<span class="mu">m</span><br>' +
        '<span class="s">S</span><sub>t</sub> = max( 0 , <span class="s">S</span><sub>t-1</sub> + ( <span class="s">z</span><sub>t</sub> &minus; <span class="k">k</span> ) ) , &nbsp; signal when <span class="s">S</span><sub>t</sub> &#8805; <span class="h">h</span> &nbsp;(<span class="k">k = 1.04</span>, <span class="h">h = 2.26</span>, no reset)<br>' +
        'same threshold in cases: <span class="h">U</span><sub>t</sub> = &#8968; <span class="mu">m</span> + &radic;<span class="mu">m</span> ( <span class="h">h</span> + <span class="k">k</span> &minus; <span class="s">S</span><sub>t-1</sub> ) &#8969;' +
      '</div>' +
      '<div class="epr-legend">' + leg(C.expected, "expected m (baseline mean)") + leg(C.alarm, "k = 1.04 reference value") + leg(C.alarmStrong, "h = 2.26 threshold / U threshold in cases") + leg(C.accent, "Sₜ CUSUM") + '</div>';
    function leg(color, text) { return '<span class="epr-leg"><span class="epr-sw" style="background:' + color + '"></span>' + text + '</span>'; }

    var ML = 54, MR = 22, CW = 760, A0 = 26, A1 = 142, B0 = 184, B1 = 272;
    var x = lin(0, N - 1, ML, CW - MR);
    var maxA = Math.max(Math.max.apply(null, counts), Math.max.apply(null, U.slice(B))) + 2;
    var y1 = lin(0, maxA, A1, A0);
    var maxB = Math.max(H * 1.8, Math.max.apply(null, S.slice(B)) + 0.4);
    var y2 = lin(0, maxB, B1, B0);
    function cy2(v) { return Math.max(B0, Math.min(B1, y2(v))); }

    function drawChart() {
      clear(chart);
      var g = svg("g", {}, chart), cur = st.cur;
      // baseline shading
      svg("rect", { x: ML, y: A0, width: x(B - 0.5) - ML, height: B1 - A0, fill: C.ink, opacity: 0.04 }, g);
      svg("text", { x: ML + 4, y: A0 + 12, "font-size": 11, fill: C.muted }, g).textContent = "baseline: estimate m";
      svg("line", { x1: x(B - 0.5), y1: A0, x2: x(B - 0.5), y2: B1, stroke: C.muted, "stroke-width": 1.2, "stroke-dasharray": "3 4", opacity: 0.7 }, g);
      svg("text", { x: x(B - 0.5) + 4, y: A0 + 12, "font-size": 11, fill: C.muted }, g).textContent = "monitoring";
      // panel titles + baselines
      svg("text", { x: ML, y: A0 - 10, "font-size": 12.5, "font-weight": 600, fill: C.ink }, g).textContent = "weekly cases";
      svg("text", { x: ML, y: B0 - 10, "font-size": 12.5, "font-weight": 600, fill: C.ink }, g).textContent = "CUSUM Sₜ (standardized)";
      svg("line", { x1: ML, y1: A1, x2: CW - MR, y2: A1, stroke: C.muted, "stroke-width": 1 }, g);
      svg("line", { x1: ML, y1: B1, x2: CW - MR, y2: B1, stroke: C.muted, "stroke-width": 1 }, g);
      // expected m line
      svg("line", { x1: ML, y1: y1(m), x2: CW - MR, y2: y1(m), stroke: C.expected, "stroke-width": 1.4, "stroke-dasharray": "4 5" }, g);
      svg("text", { x: CW - MR, y: y1(m) - 4, "font-size": 11, fill: C.expected, "text-anchor": "end" }, g).textContent = "expected m = " + m.toFixed(1);
      [5, 10, 15].forEach(function (t) { if (t < maxA) { svg("text", { x: ML - 8, y: y1(t) + 4, "font-size": 10.5, fill: C.muted, "text-anchor": "end" }, g).textContent = t; } });
      // case bars
      var bw = Math.min(13, (CW - MR - ML) / N * 0.62);
      for (i = 0; i < N; i++) {
        var col = i < B ? "#b8c4d4" : (U[i] != null && counts[i] >= U[i] ? C.alarmStrong : C.accent);
        svg("rect", { x: x(i) - bw / 2, y: y1(counts[i]), width: bw, height: A1 - y1(counts[i]), rx: 2, fill: col, opacity: i < B ? 0.55 : 0.6 }, g);
      }
      // CUSUM case-count threshold U_t (step line over monitoring)
      var du = "";
      for (i = B; i < N; i++) du += (i === B ? "M" : "L") + x(i).toFixed(1) + " " + y1(U[i]).toFixed(1) + " ";
      svg("path", { d: du, fill: "none", stroke: C.alarmStrong, "stroke-width": 1.8, "stroke-dasharray": "5 3" }, g);
      svg("text", { x: x(B) + 3, y: y1(U[B]) - 5, "font-size": 11, "font-weight": 600, fill: C.alarmStrong }, g).textContent = "epidemic threshold Uₜ";
      // panel B: h line + S up to cursor
      svg("line", { x1: ML, y1: y2(H), x2: CW - MR, y2: y2(H), stroke: C.alarmStrong, "stroke-width": 2, "stroke-dasharray": "6 4" }, g);
      svg("text", { x: CW - MR, y: y2(H) - 5, "font-size": 12, "font-weight": 600, fill: C.alarmStrong, "text-anchor": "end" }, g).textContent = "h = 2.26";
      svg("text", { x: ML - 8, y: y2(0) + 4, "font-size": 10.5, fill: C.muted, "text-anchor": "end" }, g).textContent = "0";
      var dl = "", da = "M" + x(B).toFixed(1) + " " + cy2(0).toFixed(1) + " ";
      for (i = B; i <= cur; i++) { dl += (i === B ? "M" : "L") + x(i).toFixed(1) + " " + cy2(S[i]).toFixed(1) + " "; da += "L" + x(i).toFixed(1) + " " + cy2(S[i]).toFixed(1) + " "; }
      da += "L" + x(cur).toFixed(1) + " " + cy2(0).toFixed(1) + " Z";
      svg("path", { d: da, fill: C.accentSoft }, g);
      svg("path", { d: dl, fill: "none", stroke: C.accent, "stroke-width": 2.4, "stroke-linejoin": "round", "stroke-linecap": "round" }, g);
      if (alarm >= 0 && alarm <= cur) {
        svg("line", { x1: x(alarm), y1: B0, x2: x(alarm), y2: B1, stroke: C.alarmStrong, "stroke-width": 2, opacity: 0.4 }, g);
        svg("circle", { cx: x(alarm), cy: cy2(S[alarm]), r: 4.4, fill: C.alarmStrong }, g);
        svg("text", { x: x(alarm), y: B0 + 11, "font-size": 11, "font-weight": 600, fill: C.alarmStrong, "text-anchor": "middle" }, g).textContent = "epidemic signal";
      }
      // cursor
      svg("line", { x1: x(cur), y1: A0, x2: x(cur), y2: B1, stroke: C.ink, "stroke-width": 1.5, opacity: 0.55 }, g);
      svg("circle", { cx: x(cur), cy: y1(counts[cur]), r: 3.5, fill: C.ink }, g);
      svg("text", { x: (ML + CW - MR) / 2, y: 296, "font-size": 12, fill: C.muted, "text-anchor": "middle" }, g).textContent = "week (drag across to move; the CUSUM follows)";
    }

    function chip(l, v, c) { return '<div class="epr-chip ' + (c || "") + '"><span>' + l + '</span><span class="v epr-spin">' + v + '</span></div>'; }
    function render() {
      var i = st.cur, sig = S[i] >= H, prevS = i > B ? S[i - 1] : 0;
      read.innerHTML =
        chip("week", "#" + (i + 1)) +
        chip("cases xₜ", counts[i] + "", counts[i] >= U[i] ? "bad" : "") +
        chip("zₜ", z[i].toFixed(2), z[i] > 0 ? "warn" : "good") +
        chip("CUSUM Sₜ", S[i].toFixed(2), sig ? "bad" : "") +
        chip("threshold Uₜ", U[i] + " cases", "") +
        chip("status", sig ? "EPIDEMIC" : "below h", sig ? "bad" : "good");
      hint.className = "epr-hint " + (sig ? "bad" : "");
      hint.innerHTML = "<b>Week " + (i + 1) + ":</b> " + counts[i] + " cases. z = (" + counts[i] + " &minus; " + m.toFixed(1) + ")/&radic;" + m.toFixed(1) + " = " + z[i].toFixed(2) +
        ". Sₜ = max(0, " + prevS.toFixed(2) + " + (" + z[i].toFixed(2) + " &minus; 1.04)) = <b>" + S[i].toFixed(2) + "</b>. " +
        "This week the count threshold is Uₜ = " + U[i] + " cases. " +
        (sig ? "Sₜ &#8805; h, so the epidemic threshold is crossed." : "Below h = 2.26.");
      drawChart();
    }

    function setCur(i) { i = Math.max(B, Math.min(N - 1, Math.round(i))); if (i === st.cur) return; st.cur = i; scrub.value = i; render(); }
    function weekFromEvent(ev) {
      var r = chart.getBoundingClientRect();
      var vbx = (ev.clientX - r.left) / r.width * CW;
      return (vbx - ML) / (CW - MR - ML) * (N - 1);
    }
    var dragging = false;
    chart.addEventListener("pointerdown", function (ev) { dragging = true; chart.setPointerCapture(ev.pointerId); setCur(weekFromEvent(ev)); });
    chart.addEventListener("pointermove", function (ev) { if (ev.pointerType === "mouse" && ev.buttons === 0) { setCur(weekFromEvent(ev)); return; } if (dragging) setCur(weekFromEvent(ev)); });
    chart.addEventListener("pointerup", function () { dragging = false; });
    scrub.addEventListener("input", function () { setCur(parseInt(this.value, 10)); });

    render();
  }

  if (document.readyState === "loading") document.addEventListener("DOMContentLoaded", init);
  else init();
})();
